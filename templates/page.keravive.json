    "faq_MxRhTP": {
      "type": "faq",
      "blocks": {
        "faq_BhgdwA": {
          "type": "faq",
          "settings": {
            "question": "What does it mean to have poor scalp health?",
            "answer": "Even with all the effort we put into our skincare routines, we often forget about the skin under our hair. The scalp is its own environment, or microbiome. When not properly cleansed and nourished, it often struggles with itching, flaking, hair thinning or loss, and sometimes even complete baldness."
          }
        },
        "faq_YJiAQC": {
          "type": "faq",
          "settings": {
            "question": "Do scalp issues affect men and women?",
            "answer": "Yes! It’s estimated that 85% of men and 50% of women experience hair loss, thinning, and poor scalp health². Factors that can play a role in this include post-partum stress, hormonal imbalances, chemical damage from hair coloring or other treatments, and build-up from styling products."
          }
        },
        "faq_XRibXm": {
          "type": "faq",
          "settings": {
            "question": "Is Keravive an invasive treatment? Does it hurt?",
            "answer": "No, not at all. Keravive is a noninvasive, relaxing and rejuvenating treatment."
          }
        },
        "faq_cVfHmQ": {
          "type": "faq",
          "settings": {
            "question": "Is it a one-time treatment?",
            "answer": "Keravive achieves the best results when you receive a series—usually 3 treatments, spaced a month apart. In between, you use an exclusive take-home spray to boost your benefits."
          }
        },
        "faq_UJ4eQg": {
          "type": "faq",
          "settings": {
            "question": "Can Keravive be paired with other treatments?",
            "answer": "Yes! Your provider may recommend Keravive to complement other hair restoration or scalp health treatments."
          }
        },
        "faq_JyJHpa": {
          "type": "faq",
          "settings": {
            "question": "Is Keravive designed for all scalp/skin types?",
            "answer": "The Keravive treatment is designed for all scalp & hair types, including braids, extensions, locks, dyed hair, and more. Your provider or skincare professional may choose a specific type of treatment (partial or full scalp) to support your overall scalp and hair goals."
          }
        },
        "faq_mnBUAe": {
          "type": "faq",
          "settings": {
            "question": "How long does the treatment take?",
            "answer": "Depending on your personalized treatment experience (partial or full scalp), your Keravive treatment can vary from 30 minutes to 60 minutes."
          }
        }
      },
