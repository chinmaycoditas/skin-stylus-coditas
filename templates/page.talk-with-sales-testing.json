            "author_details": "MD Facial Plastic and Reconstructive"
          }
        },
        "quote_GpDDen": {
          "type": "quote",
          "settings": {
            "quote": "Hydrafacial has filled in every missing piece in our medical spa. Not only did it attract new clientele, <|our retention rate after our first 5 months grew to 92%|>.",
            "author": "Kirsten Lindh",
            "author_details": "Regen Medical Aesthetics"
          }
        },
        "quote_PJRCnB": {
