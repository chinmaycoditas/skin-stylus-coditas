            "author": "Nilan Holmes",
            "author_details": "Celebrity Facialist MILTON KEYNES, England"
          }
        },
        "quote_PMPnEN": {
          "type": "quote",
          "settings": {
            "quote": "Hydrafacial Syndeo not only drives <|patient satisfaction|> but also helps differentiate what I offer, in terms of <|personalized treatments|> and combinations I can customize for my patients.",
            "author": "An Haiying",
            "author_details": "Founder of Dongtian Skin Care Center BEIJING, China"
          }
        },
        "quote_TPmCka": {
          "type": "quote",
          "settings": {
            "quote": "Hydrafacial has played a <|significant role in the growth of my esthetics business|> because it is a real gateway treatment for my clients. It’s a real blessing to lead a successful career and business while making my own schedule, earning over six-figures, and forming such meaningful human connections in the treatment room.",
