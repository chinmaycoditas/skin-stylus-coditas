            "image": "shopify://shop_images/Model_Looking_At_Gunkie.png",
            "image_first": false
          }
        },
        "item_BBegEM": {
          "type": "item",
          "settings": {
            "title_1": "Plays Nice With Others",
            "description_1": "<p>Hydrafacial treatments work synergistically with your clients’ other treatments, amplifying their results even further when compared to those treatments alone.</p><ul><li><strong>Up to 30% visible reduction in brown spots using IPL in combination with Hydrafacial¹</strong></li><li><strong>2X smoother skin when paired with non-ablative fractional laser or fractional radio frequency.²</strong></li><li><strong>2X firmer skin when paired with Radio Frequency or Focused Ultrasound³</strong></li><li><strong>50% smoother skin when paired with ablative fractional laser ⁴</strong></li></ul>",
            "cta_label_1": "GET STARTED",
