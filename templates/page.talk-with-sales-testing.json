        "item_UawGQi": {
          "type": "item",
          "settings": {
            "title_1": "Results You Can See",
            "description_1": "<p>Clinically proven to improve skin’s overall appearance, Hydrafacial’s cutting-edge and patented Vortex-Fusion Technology cleanses, extracts, and hydrates for instantly visible results.</p><ul><li><strong>Unmatched glow your clients will love.</strong></li><li><strong>Personalized treatments for any skin type and concern.</strong></li><li><strong>Client satisfaction from start to finish.</strong></li></ul>",
            "cta_label_1": "GET STARTED",
