    "quote_slider_XLkU7L": {
      "type": "quote-slider",
      "blocks": {
        "quote_AqXzRt": {
          "type": "quote",
          "settings": {
            "image": "shopify://shop_images/Headshot_Dendy_Engelman_260x260_faca7516-9f6b-4044-8716-bf583c2abffc.jpg",
            "quote": "As a dermatologist, I always recommend treatments backed by science and proven results. Hydrafacial is an excellent choice for younger consumers looking to invest in their skin health early. It combines advanced technology with clinically vetted techniques to <|deliver both immediate glow and longterm skin benefits|>, making it a <|trusted|> option in aesthetic skincare.",
            "author": "Dr. Dendy Engelman",
            "author_details": "Board Certified Cosmetic Dermatologist | New York, NY"
          }
        },
        "quote_EEUDp7": {
          "type": "quote",
          "settings": {
            "image": "shopify://shop_images/prather-new.jpg",
            "quote": "There is a big role that <|Hydrafacial treatments play in pretreating the skin in terms of cleansing before any laser, any peel|>, anything you do despite what your baseline skin is. You are cleansing the skin to create better penetration. <|Hydrafacial is an integral part of good skin health|> and feels good! ",
            "author": "DR. HEIDI PRATHER",
            "author_details": "Board-Certified Dermatologist | Austin, Texas "
          }
        },
        "quote_PbqhEU": {
          "type": "quote",
          "settings": {
            "image": "shopify://shop_images/Headshot_Tiffany_Liberian_260x260_95366b6c-0307-419c-8d49-d35dec3f64c3.jpg",
            "quote": "When I started my business as a solo esthetician, I didn’t have a lot of money to invest in a device, but I knew my patients would <|love their results from Hydrafacial and Keravive|>. The company set me up for success with financing, and it turned out to be the <|best risk I took|>. Within a year, my business <|grew 200 percent!|> Now, approximately 70 percent of my services are Hydrafacial treatments thanks to its versatility and customizations. Hydrafacial delivers every single time!",
            "author": "Tiffany Libiran",
            "author_details": "Owner & Esthetician of MadisonCrown Skin | San Francisco, CA"
          }
        },
        "quote_Wr94jA": {
          "type": "quote",
          "settings": {
            "image": "shopify://shop_images/HeadShot_Abigail_Quinn_260x260_41a38e4a-0fad-4bd8-b415-9bc68c8816c2.jpg",
            "quote": "Hydrafacial is a company that sticks with you and <|provides a variety of resources|>. The biggest of them being that they share their knowledge on other things happening in the industry as well. They truly want you to succeed and will help you get there. Their trainings will make sure you are staying up to date with trends in the industry, how to handle all skin types & how to grow your own confidence. With Hydrafacial by my side and guiding me through all of their in-depth trainings, I was able to <|increase my clientele by 62 percent|>. Hydrafacial will transform your business!",
            "author": "Abigail Quinn",
            "author_details": "Owner & Esthetician of WestFern Spa | McAllen, Texas"
          }
        }
      },
      "block_order": [
        "quote_AqXzRt",
        "quote_EEUDp7",
        "quote_PbqhEU",
        "quote_Wr94jA"
      ],
