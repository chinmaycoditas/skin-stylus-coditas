        "disclaimer_gcdAUm": {
          "type": "disclaimer",
          "settings": {
            "disclaimer": "<p>¹ Data on file. HydraFacial, LLC</p><p>²Based on a 5-7 day work week, 50 weeks/ year, $250 Deluxe SRP, $325 Platinum SRP</p><p>³In a clinical study 24 hours after 1 Hydrafacial treatment with Hydralock HA booster. Based on Corneometer measurements of 38 participants before and 24 hours after treatment in a clinical study. Individual results may vary.</p><p>³*Based on QuantifiCare skin analysis of 38 participants before, immediately after,<br/>and 24 hours post-treatment in a clinical study. Individual results may vary.</p><p>⁴Participant perception of 10 female patients receiving 1 Hydrafacial treatment. Data on file Hydrafacial, LLC.</p><p>⁵Based on Investigator assessment of 20 participants with mild to moderate acne who received 6 Clarifying Hydrafacial Treatments over 12 weeks. Individual results may vary.</p><p>⁶Based on perception of 44 participants receiving a series of 3 Hydrafacial Keravive treatments with daily application of take-home peptide spray in between treatments for 20 weeks.</p>"
          }
        }
