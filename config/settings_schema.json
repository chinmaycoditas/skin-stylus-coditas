      },
      {
        "type": "url",
        "id": "eyebrow_brand_2_url",
        "label": "Brand 2 URL"
      },
      {
        "type": "text",
        "id": "eyebrow_brand_2_host",
        "label": "Brand 2 Host",
        "default": "hydrafacial.com"
      }
    ]
  }
