      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Image"
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "textarea",
        "id": "alt_menu_pages",
        "label": "t:settings_schema.sections.header.alt_menu_pages",
        "info": "t:settings_schema.sections.header.comma_separated_handles"
      }
    ]
  },
  {
    "name": "t:settings_schema.global_theme_settings.logo.name",
    "settings": [
      {
        "type": "select",
        "id": "logo_type",
        "options": [
          {
            "label": "t:settings_schema.global_theme_settings.logo.copyright",
            "value": "copyright"
          },
          {
            "label": "t:settings_schema.global_theme_settings.logo.trademark",
            "value": "trademark"
          }
        ],
        "default": "trademark",
        "label": "t:settings_schema.global_theme_settings.logo.logo_type"
      },
      {
        "type": "image_picker",
        "id": "logo_image",
        "label": "t:settings_schema.global_theme_settings.logo.logo_image",
        "info": "t:settings_schema.global_theme_settings.logo.logo_image_info"
      },
      {
        "type": "range",
        "id": "logo_image_max_width",
        "label": "t:settings_schema.global_theme_settings.logo.logo_image_max_width",
        "min": 80,
        "max": 400,
        "step": 10,
        "unit": "px",
        "default": 220
      }
    ]
  },
  {
    "name": "Eyebrow Navigation",
