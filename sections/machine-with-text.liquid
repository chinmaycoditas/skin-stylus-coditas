{%- assign s = section.settings -%}

<div
  id="machine-with-text-{{ s.id_number }}"
  class="relative flex flex-col gap-10 lg:gap-20 items-center pt-10 lg:pt-[60px] pb-[54px] lg:pb-[150px] lg:h-[var(--section-height-desktop)]"
  style="--section-height-desktop: {{ s.section_height_desktop }}px">
  <h1 class="max-w-[810px] text-center text-h2-mob/[50px] lg:text-h2/[70px] tracking-[-0.09px] lg:tracking-[-0.13px] {% unless settings.remove_capitalize %}capitalize{% endunless %}">{% render 'blue', text: s.heading %}</h1>

  {%- capture slider_options %}
    '{
      "perPage": 1,
      "pagination": false,
      "focus": "center",
      "arrows": true,
      "type": "fade",
      "gap": "16px",
      "padding": {"left": "15px", "right": "15px"},
      "mediaQuery": "min",
      "breakpoints": {
        "1024": {
          "gap": "41px",
          "padding": {"left": "40px", "right": "40px"}
        }
      }
    }'
  {% endcapture -%}

  {%- capture connected_slider_options %}
    '{
      "perPage": 1,
      "arrows": false,
      "pagination": false
    }'
  {% endcapture -%}

  <div class="splide max-w-screen" data-connected-slider={{ connected_slider_options }}>
    <div class="splide__track">
      <ul class="splide__list">
        {% for block in section.blocks %}
          {% assign b = block.settings %}
          <li class="splide__slide !border-0">
            {% render 'responsive-image', 
              image: b.image_desktop, 
              class: "hidden lg:block w-full h-full", 
              image_class: "max-h-[60dvh]"
            %}

            {% render 'responsive-image', 
              image: b.image_mobile, 
              class: "lg:hidden h-full",
              cover: true
            %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="informational-slider splide pb-[30px] lg:!absolute lg:right-0 lg:top-[33%] max-w-screen lg:max-w-[570px] -translate-y-[50px] lg:translate-y-0" data-slider={{ slider_options }}>
      <div class="splide__track">
      <ul class="splide__list">
        {% for block in section.blocks %}
          {% assign b = block.settings %}
          <li class="splide__slide border-b-[1px] border-b-grey-medium lg:border-b-0">
            <div class="flex flex-col bg-white rounded-image backdrop-blur-[32.5px] p-[30px] lg:px-[50px]">
              <h3 class="text-h3-mob/10 font-light tracking-[-0.07px] {% unless settings.remove_capitalize %}capitalize{% endunless %} lg:pt-2.5 pb-[15px]">{% render 'blue', text: b.heading %}</h3>
              <hr class="h-[1px] scale-y-50 my-[9px] text-grey-medium" />
              <div class="flex flex-col gap-[22px] pt-[15px] lg:pt-[25px]">
                {% for i in (1..3) %}
                  {%- liquid
                    assign text = "feature_" | append: i | append: "_text"
                    assign icon = "feature_" | append: i | append: "_icon"
                  -%}

                  {% if b[text] != blank %}
                    <div class="grid grid-cols-[22px_1fr] gap-4">
                      {% render 'icons', icon: b[icon] %}
                      <p class="text-section-2-mob/[25px] font-light tracking-[-0.036px]">{% render 'blue', text: b[text] %}</p>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
    <div class="splide__arrows flex gap-3 w-[200px] absolute -bottom-10 lg:-bottom-[100px] left-[15px] lg:left-10 pointer-events-none [&_button:not(:disabled)]:pointer-events-auto">
      <button class="splide__arrow splide__arrow--prev !relative !left-0 !rounded-none !h-[44px] !w-[44px] !bg-none" style="background: none; transform: translateY(0);">
        {% render 'icons', icon: 'chevron-right-circle', class: "text-black block h-full w-full [&_svg]:block [&_svg]:!h-full [&_svg]:!w-full" %}
      </button>
      <button class="splide__arrow splide__arrow--next !relative !right-0 !rounded-none !h-[44px] !w-[44px] !bg-none" style="background: none; transform: translateY(0);">
        {% render 'icons', icon: 'chevron-right-circle', class: "text-black block h-full w-full [&_svg]:block [&_svg]:!h-full [&_svg]:!w-full" %}
      </button>
    </div>

    {%- assign cta_class = 'absolute bottom-[var(--bottom-value-mobile)] right-[15px] lg:bottom-[var(--bottom-value-desktop)] lg:right-10 button-primary-black w-[170px]' -%}
    {% if settings.remove_capitalize %}
      {% assign cta_class = cta_class | append: ' !normal-case' %}
    {% endif %}

    {%- capture cta_style -%}
      --bottom-value-mobile: {{ s.cta_bottom_value_mobile }}px; --bottom-value-desktop: {{ s.cta_bottom_value_desktop }}px
    {%- endcapture -%}

    {%- if s.popup_form_override -%}
      {% render 'popup-input', class: cta_class, text: s.cta_button_text, style: cta_style %}
    {%- elsif s.cta_button_text != blank and s.cta_button_url != blank -%}
      <a
        href="{{ s.cta_button_url }}"
        class="{{ cta_class }}"
        style="{{ cta_style }}"
      >
        {{ s.cta_button_text }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:settings_schema.sections.machine_with_text.name",
  "tag": "section",
  "class": "darker-grey-white-gradient",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings_schema.general.heading"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "t:settings_schema.general.cta_button_text"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "t:settings_schema.general.cta_button_url"
    },
    {
      "type": "number",
      "id": "cta_bottom_value_mobile",
      "label": "t:settings_schema.sections.machine_with_text.cta_bottom_value_mobile_label",
      "info": "t:settings_schema.sections.machine_with_text.cta_bottom_mobile_info",
      "default": -40
    },
    {
      "type": "number",
      "id": "cta_bottom_value_desktop",
      "label": "t:settings_schema.sections.machine_with_text.cta_bottom_value_desktop_label",
      "info": "t:settings_schema.sections.machine_with_text.cta_bottom_desktop_info",
      "default": -100
    },
    {
      "type": "number",
      "id": "section_height_desktop",
      "label": "t:settings_schema.sections.machine_with_text.section_height_desktop_label",
      "info": "t:settings_schema.sections.machine_with_text.section_height_desktop_info",
      "default": 1100
    },
    {
      "type": "header",
      "content": "Unique Section ID"
    },
    {
      "type": "paragraph",
      "content": "The ID for this section will be 'machine-with-text-#' based on the number chosen below. The default is 'machine-with-text-1'"
    },
    {
      "type": "range",
      "id": "id_number",
      "label": "ID Number",
      "max": 5,
      "min": 1,
      "step": 1,
      "default": 1,
      "info": "If using this section multiple times on the same page, assign a different number to each one."
    },
    {
      "type": "checkbox",
      "id": "popup_form_override",
      "label": "Override CTA links with Popup Form",
      "info": "Requires the Form Popup section to be on the template to work."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:settings_schema.sections.machine_with_text.slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "t:settings_schema.general.image_desktop"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:settings_schema.general.image_mobile"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:settings_schema.general.heading"
        },
      {
          "type": "header",
          "content": "t:settings_schema.sections.machine_with_text.feature_details_1"
        },
        {
          "type": "text",
          "id": "feature_1_text",
          "label": "t:settings_schema.general.text",
          "info": "t:settings_schema.general.blue_info"
        },
        {
          "type": "select",
          "id": "feature_1_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "blue-check",
              "label": "t:settings_schema.general.icons.blue-check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "blue-check"
        },
      {
          "type": "header",
          "content": "t:settings_schema.sections.machine_with_text.feature_details_2"
        },
        {
          "type": "text",
          "id": "feature_2_text",
          "label": "t:settings_schema.general.text",
          "info": "t:settings_schema.general.blue_info"
        },
        {
          "type": "select",
          "id": "feature_2_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "blue-check",
              "label": "t:settings_schema.general.icons.blue-check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "blue-check"
        },
      {
          "type": "header",
          "content": "t:settings_schema.sections.machine_with_text.feature_details_3"
        },
        {
          "type": "text",
          "id": "feature_3_text",
          "label": "t:settings_schema.general.text",
          "info": "t:settings_schema.general.blue_info"
        },
        {
          "type": "select",
          "id": "feature_3_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "blue-check",
              "label": "t:settings_schema.general.icons.blue-check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "blue-check"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "t:settings_schema.sections.machine_with_text.name"
    }
  ]
}
{% endschema %}
