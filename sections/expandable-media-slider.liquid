{%- assign s = section.settings -%}

{%- capture slider_options -%}
  '{
    "pagination": true,
    "start": 0,
    "snap": true,
    "gap": "22px",
    "arrows": false,
    "padding": {"right": "48px", "left": "15px"},
    "mediaQuery": "min",
    "breakpoints": {
      "1024": {
        "padding": {"right": "100px", "left": "38px"},
        "focus": 0,
        "trimSpace": true,
        "pagination": false
      }
    }
  }'
{%- endcapture -%}

<div 
  id="expandable-media-{{ s.id_number }}"
  class="flex flex-col gap-10 pt-[60px] pb-10 lg:pb-[30px] lg:pt-10 {% if s.show_gradient %}white-darker-grey-gradient{% endif %} group/mobile-expansion"
>
<div class="flex flex-col lg:flex-row {% if s.center_heading %}lg:justify-center{% else %}lg:justify-between{% endif %} gap-[30px] lg:gap-0 pb-2.5 pl-[15px] lg:px-[38px]">
    <div class="flex flex-col lg:w-1/2 {% if s.subheading != blank %}gap-[22px]{% endif %}">
      <h2 class="text-h3-mob/10 lg:text-h3/[60px] font-light tracking-[-0.07px] lg:tracking-[-0.11px] {% if s.center_heading %}text-center{% endif %} {% unless settings.remove_capitalize %}capitalize{% endunless %}">{% render 'blue', text: s.heading %}</h2>
      <h3 class="text-body/[23px] lg:text-section-3/7 font-light tracking-[-0.032px] lg:tracking-[-0.042px]">{% render 'blue', text: s.subheading %}</h3>
    </div>
    {% if s.cta_text and s.cta_url %}
      <div class="flex lg:justify-end lg:items-end">
        {%- assign cta_class = 'button-primary-black w-[174px]' -%}
        {% if settings.remove_capitalize %}
          {% assign cta_class = cta_class | append: ' !normal-case' %}
        {% endif %}
        
        {%- if s.popup_form_override -%}
          {% render 'popup-input', class: cta_class, text: s.cta_text %}
        {%- else -%}
          <a href="{{ s.cta_url }}" class="{{ cta_class }}">{{ s.cta_text }}</a>
        {%- endif -%}      
      </div>
    {% endif %}
  </div>
  
  <input id="expanded-splide-lock" class="hidden" type="checkbox" data-scroll-lock/>
  <div class="splide expandable__slider max-w-screen [&_.splide\_\_pagination]:!hidden group/slider" data-slider={{ slider_options }}>
    <div class="splide__track">
      <ul class="splide__list">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}

          <li class="splide__slide relative group transition-all duration-500 lg:max-h-[675px] lg:!w-[600px] [&.is-expanded]:lg:!w-[92%] lg:max-w-[1200px]" data-video-no-change>
            {%- liquid 
              assign mobile_autoplay = false
            -%}
            
              {%- liquid 
                assign mobile_image_class = "lg:hidden rounded-image h-full w-full mobile__image block"
                if b.mobile_video != blank
                  assign mobile_image_class = mobile_image_class | append: " group-[&.mobile\_\_expanded]/slider:hidden"
                endif

                assign mobile_video_class = "lg:hidden h-full [&_svg]:text-white rounded-image overflow-hidden group-[&.mobile\_\_expanded]/slider:rounded-none"
                if b.mobile_image != blank
                  assign mobile_video_class = mobile_video_class | append: " hidden group-[&.mobile\_\_expanded]/slider:block"
                endif
              -%}
              {% if b.mobile_image != blank %}
                {%- render 'responsive-image', 
                  image: b.mobile_image, 
                  class: mobile_image_class, 
                  cover: true,
                  pb_hack: "129.50%" 
                -%}
              {% endif %}

              {% if b.mobile_video != blank %}
                {% render 'video', 
                  video: b.mobile_video, 
                  class: "mobile-video",
                  container_class: mobile_video_class,
                  pb_hack: "129.50%",
                  play_button: true,
                  muted: true,
                  autoplay: mobile_autoplay
                %}
              {% endif %}
            

            {%- liquid 
              assign desktop_image_class = "hidden lg:block rounded-image h-full"
              if b.desktop_video != blank
                assign desktop_image_class = desktop_image_class | append: " opacity-100 pointer-events-auto group-[&.is-expanded]:lg:opacity-0 group-[&.is-expanded]:pointer-events-none transition-all"
              endif

              assign desktop_video_class = "hidden lg:block h-full [&_svg]:text-white rounded-image overflow-hidden"
              if b.desktop_image != blank
                assign desktop_video_class = desktop_video_class | append: " opacity-0 pointer-events-none group-[&.is-expanded]:lg:opacity-100 group-[&.is-expanded]:pointer-events-auto transition-all"
              endif
            -%}
            <div class="grid grid-rows-1 grid-cols-1 [&>*]:row-span-full [&>*]:col-span-full h-full">
              {% if b.desktop_image != blank %}
                {%- render 'responsive-image',
                  image: b.desktop_image, 
                  class: desktop_image_class,
                  cover: true,
                -%}
              {% endif %}

              {% if b.desktop_video != blank %}
                {% render 'video', 
                  video: b.desktop_video, 
                  class: "h-full w-full",
                  container_class: desktop_video_class,
                  play_button: true,
                  muted: true,
                  autoplay: false
                %}
              {% endif %}
            </div>

            <button type="button" class="hidden lg:block" data-expand-media>
              {% render 'icons', icon: "plus", class: "absolute top-4 right-4 bg-[#ffffff59] backdrop-blur-[17.5px] p-[15px] rounded-full hover:cursor-pointer group-[&.is-expanded]:rotate-[405deg] transition-all", svg_class: "h-6  text-white" %}
            </button>

            <div class="lg:hidden">
              {% render 'icons', 
                icon: "plus", 
                class: "absolute top-4 right-4 bg-[#ffffff59] backdrop-blur-[17.5px] p-[15px] rounded-full hover:cursor-pointer group-[&.mobile\_\_expanded]/slider:rotate-[405deg] transition-all", 
                svg_class: "h-6 text-white"
                attribute: "data-expand-media-mobile" 
              %}
            </div>

            <div class="media__text-overlay pointer-events-none flex flex-col absolute bottom-10 lg:max-w-[397px] group-[&.is-expanded]:lg:max-w-[433px] pr-4 lg:pr-0 opacity-100 transition-all {% if b.heading != blank %}left-[26px] inset-0 h-full justify-end group-[&.is-expanded]:justify-between group-[&.mobile\_\_expanded]/slider:justify-between group-[&.mobile\_\_expanded]/slider:left-0 lg:py-9 pb-[18px] group-[&.mobile\_\_expanded]/slider:pt-10 group-[&.mobile\_\_expanded]/slider:px-[18px] group-[&.mobile\_\_expanded]/slider:expandable-media-content-box-gradient{% else %} left-[26px]{% endif %}">
              <div class="flex flex-col gap-1">
                <span class="text-section-1-mob/[25px] lg:text-section-3/7 text-white tracking-[-0.036px] lg:tracking-[-0.042px] {% unless settings.remove_capitalize %}capitalize{% endunless %}">{% render 'blue', text: b.title %}</span>
                <h4 class="text-h3-mob/10 lg:text-h4/[50px] text-white font-light tracking-[-0.07px] lg:tracking-[-0.09px] {% unless settings.remove_capitalize %}capitalize{% endunless %} w-[260px] lg:w-auto">{% render 'blue', text: b.caption %}</h4>
              </div>

               {% if b.heading != blank %}
                <div class="expandable__content-box grid grid-rows-[0fr] group-[&.is-expanded]:grid-rows-[1fr] group-[&.mobile\_\_expanded]/slider:grid-rows-[1fr] transition-all pb-[56px] lg:pb-0">
                  <div class="overflow-hidden">
                    <div class="flex flex-col items-start gap-5 lg:gap-[30px] p-[30px] pb-2.5 lg:pb-[30px] bg-[#babcbe59] rounded-image backdrop-blur-[17.5px]">
                      <h5 class="text-white text-section-1/8 font-light {% unless settings.remove_capitalize %}capitalize{% endunless %} tracking-[-0.56px]">{% render 'blue', text: b.heading %}</h5>
                      <ul class="flex flex-col gap-4 lg:gap-[22px] pl-[5px] lg:pl-0">
                        {% for i in (1..3) %}
                          {%- liquid
                            assign text = "feature_" | append: i | append: "_text"
                            assign icon = "feature_" | append: i | append: "_icon"
                          -%}
                          <li class="flex items-start gap-[22px]">
                            {% render 'icons', icon: b[icon], class: 'text-white' %}
                            <span class="text-white text-section-1-mob/[25px] lg:text-section-3/7 font-normal tracking-[-0.036px] lg:tracking-[-0.042px]">{{ b[text] }}</span>
                          </li>
                        {% endfor %}
                      </ul>
                      {% if b.content_box_cta_text != blank and b.content_box_cta_url != blank %}
                        {%- if b.popup_form_override -%}
                          <input
                            type="radio"
                            id="popup-form--{{ section.id }}--{{ block.id }}"
                            name="popup-form"
                            class="hidden"
                            data-form-popup
                            data-scroll-lock
                          >
                          <label 
                            for="popup-form--{{ section.id }}--{{ block.id }}"
                            class="button-primary-white {% if settings.remove_capitalize %}!normal-case{% endif %} w-[134px] pointer-events-auto"
                          >
                            {{ b.content_box_cta_text }}
                          </label>
                        {%- else -%}
                          <a
                            href="{{ b.content_box_cta_url }}" 
                            class="button-primary-white {% if settings.remove_capitalize %}!normal-case{% endif %} w-[134px] pointer-events-auto"
                          >
                            {{ b.content_box_cta_text }}
                          </a>
                        {%- endif -%}
                      {% endif %}
                    </div>
                  </div>
                </div>
               {% endif %}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:settings_schema.sections.expandable_media_slider.name",
  "tag": "section",
  "class": "section-expandable-media-slider no-max white-to-soft-grey",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_gradient",
      "label": "t:settings_schema.general.display.show_gradient"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings_schema.general.heading",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "checkbox",
      "id": "center_heading",
      "label": "Center Heading",
      "default": false
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:settings_schema.general.subheading",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:settings_schema.general.cta_button_text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:settings_schema.general.cta_button_url"
    },
    {
      "type": "checkbox",
      "id": "popup_form_override",
      "label": "Override CTA links with Popup Form",
      "info": "Requires the Form Popup section to be on the template to work."
    },
    {
      "type": "header",
      "content": "Unique Section ID"
    },
    {
      "type": "paragraph",
      "content": "The ID for this section will be 'expandable-media-#' based on the number chosen below. The default is 'expandable-media-1'"
    },
    {
      "type": "range",
      "id": "id_number",
      "label": "ID Number",
      "max": 5,
      "min": 1,
      "step": 1,
      "default": 1,
      "info": "If using this section multiple times on the same page, assign a different number to each one."
    }
  ],
  "blocks": [
    {
      "type": "media_slide",
      "name": "t:settings_schema.sections.blocks.expandable_media_slider.slide_name",
      "settings": [
        {
          "type": "video",
          "id": "desktop_video",
          "label": "t:settings_schema.general.video_desktop"
        },
        {
          "type": "video",
          "id": "mobile_video",
          "label": "t:settings_schema.general.video_mobile"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "t:settings_schema.general.image_desktop"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "t:settings_schema.general.image_1_mobile"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:settings_schema.general.eyebrow",
          "info": "t:settings_schema.general.blue_info"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:settings_schema.general.caption",
          "info": "t:settings_schema.general.blue_info"
        },
        {
          "type": "header",
          "content": "t:settings_schema.general.components.content_box",
          "info": "t:settings_schema.general.components.content_box_info"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:settings_schema.general.heading"
        },
        {
          "type": "header",
          "content": "t:settings_schema.sections.blocks.expandable_media_slider.icon_text_1_header"
        },
        {
          "type": "select",
          "id": "feature_1_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "check",
              "label": "t:settings_schema.general.icons.check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "feature_1_text",
          "label": "t:settings_schema.general.text"
        },
        {
          "type": "header",
          "content": "t:settings_schema.sections.blocks.expandable_media_slider.icon_text_2_header"
        },
        {
          "type": "select",
          "id": "feature_2_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "check",
              "label": "t:settings_schema.general.icons.check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "feature_2_text",
          "label": "t:settings_schema.general.text"
        },
        {
          "type": "header",
          "content": "t:settings_schema.sections.blocks.expandable_media_slider.icon_text_3_header"
        },
        {
          "type": "select",
          "id": "feature_3_icon",
          "label": "t:settings_schema.general.icon",
          "options": [
            {
              "value": "check",
              "label": "t:settings_schema.general.icons.check"
            },
            {
              "value": "face-magic",
              "label": "t:settings_schema.general.icons.face_magic"
            },
            {
              "value": "sparkle",
              "label": "t:settings_schema.general.icons.sparkle"
            },
            {
              "value": "face",
              "label": "t:settings_schema.general.icons.face"
            },
            {
              "value": "clock",
              "label": "t:settings_schema.general.icons.clock"
            }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "feature_3_text",
          "label": "t:settings_schema.general.text"
        },
        {
          "type": "text",
          "id": "content_box_cta_text",
          "label": "t:settings_schema.general.cta_text",
        },
        {
          "type": "url",
          "id": "content_box_cta_url",
          "label": "t:settings_schema.general.cta_url"
        },
        {
          "type": "checkbox",
          "id": "popup_form_override",
          "label": "Override CTA links with Popup Form",
          "info": "Requires the Form Popup section to be on the template to work."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:settings_schema.sections.expandable_media_slider.name"
    }
  ]
}
{% endschema %}
