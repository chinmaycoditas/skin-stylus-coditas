{%- assign s = section.settings -%}

<div 
  id="tabs-with-slider-{{ s.id_number }}"
  data-tabs 
  class="group mt-4 lg:pt-10 lg:px-[38px] pb-5 lg:pb-[60px] {% if s.accent_yellow %}accent__yellow {% endif %}"
>
  <div class="flex flex-col items-center lg:pt-10 rounded-header-menu {% if s.gradient == "gray" %}light-grey-white-gradient{% elsif s.gradient == "white" %}white-to-transparent-gradient{% elsif s.gradient == "light-blue" %}light-blue-gradient-3{% elsif s.gradient == "light-gray-2" %}light-grey-gradient-2{% endif %}">
    <div class="flex flex-col gap-2.5 lg:gap-6 items-center lg:!bg-linear-[transparent] mx-4 rounded-header-menu pt-10 lg:pt-0">
      <h2 class="text-h1-mob/[50px] lg:text-h2/[70px] tracking-[-0.13px] text-center inline-block">
        {% if s.accent_yellow %}
          {% render 'yellow', text: s.title %}
        {% else %}
          {% render 'blue', text: s.title %}
        {% endif %}
      </h2>
      {% unless s.description == blank %}
        <div class="lg:w-[60%] !text-center text-body-mob/[23px] font-light tracking-[-0.032px] inline-block">
          {% if s.accent_yellow %}
            {% render 'yellow', text: s.description %}
          {% else %}
            {% render 'blue', text: s.description %}
          {% endif %}
        </div>
      {% endunless %}
    </div>

    {%- assign tabs = s.tabs | split: "," -%}
    <div class="lg:px-[10%]">
      <div class="max-w-screen lg:max-w-none relative mt-[50px] {% if s.description == blank %}lg:mt-8{% else %}lg:mt-[60px]{% endif %} mb-8 lg:w-full">
        <ul data-tab-container class="flex w-full justify-between lg:min-w-[968px] gap-6 pb-[22px] text-black transition-all {% if s.accent_yellow %}[&_.is-active]:text-yellow{% else %}[&_.is-active]:text-blue-cta{% endif %}">
          {%- for tab in tabs -%}
            {% comment %} below replaces invisible spaces u200B {% endcomment %}
            {% assign cleaned_tab = tab | replace: "​", "" %}
            <li class="{% if forloop.first %}pl-4{% endif %} {% if forloop.last %}pr-4{% endif %}">
              <button type="button" class="{% unless settings.remove_capitalize %}capitalize{% endunless %} text-body-small/normal lg:text-body/normal tracking-[-0.028px] whitespace-nowrap" data-tab-toggle="{{ cleaned_tab }}-{{ section.id }}">{{ tab | strip }}</button>
            </li>
          {%- endfor -%}
        </ul>

        <div class="h-px bg-dark-grey w-[calc(100%-2rem)] ml-4"></div>

        <div
          data-tab-indicator
          class="absolute -bottom-[1px] h-[4px] {% if s.accent_yellow %}bg-yellow{% else %}bg-blue-cta{% endif %} transition-all"
          style="left: 0;"
        ></div>
      </div>
    </div>

    <div class="[&>div>div:not(:first-child)>div]:hidden w-[1064px] max-w-[calc(100vw-2rem)] has-[.product-with-tabs]:lg:w-[89%]">
      {%- content_for "block", type: "homepage-tab-slider-group", id: "homepage-tab-slider-group" -%}
    </div>
  </div>
</div>

{% if s.use_border %}
  <div class="px-[18px] lg:px-[38px]">
    <span class="block border-b border-b-grey-medium"></span>
  </div>
{% endif %}

{% if s.use_second_gradient %}
  <style>
    #shopify-section-{{ section.id }} {
      position: relative;
    }
    #shopify-section-{{ section.id }}::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to bottom, transparent 0%, #F3F0EE 100%);
      pointer-events: none;
      z-index: 1;
    }
    #shopify-section-{{ section.id }} > * {
      position: relative;
      z-index: 2;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "t:settings_schema.sections.tabs_with_sliders.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_border",
      "label": "t:settings_schema.general.use_border"
    },
    {
      "type": "checkbox",
      "id": "accent_yellow",
      "label": "t:settings_schema.general.use_yellow_accent"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:settings_schema.general.title",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:settings_schema.general.description",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "text",
      "id": "tabs",
      "label": "t:settings_schema.general.tabs",
      "info": "t:settings_schema.general.comma_separated_values"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:settings_schema.general.cta_text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:settings_schema.general.cta_url"
    },
    {
      "type": "checkbox",
      "id": "reverse_arrows",
      "label": "t:settings_schema.layout.reverse_cta_arrows"
    },
    {
      "type": "select",
      "id": "gradient",
      "label": "t:settings_schema.design.gradient",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.general.gradients.none"
        },
        {
          "value": "gray",
          "label": "t:settings_schema.general.gradients.gray_to_white"
        },
        {
          "value": "white",
          "label": "t:settings_schema.general.gradients.white_to_transparent"
        },
        {
          "value": "light-blue",
          "label": "t:settings_schema.general.gradients.light_blue"
        },
        {
          "value": "light-gray-2",
          "label": "Light Gray to Transparent"
        }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "use_second_gradient",
      "label": "Use Second Gradient"
    },
    {
      "type": "header",
      "content": "Unique Section ID"
    },
    {
      "type": "paragraph",
      "content": "The ID for this section will be 'tabs-with-slider-#' based on the number chosen below. The default is 'tabs-with-slider-1'"
    },
    {
      "type": "range",
      "id": "id_number",
      "label": "ID Number",
      "max": 5,
      "min": 1,
      "step": 1,
      "default": 1,
      "info": "If using this section multiple times on the same page, assign a different number to each one."
    },
    {
      "type": "checkbox",
      "id": "popup_form_override",
      "label": "Override CTA links with Popup Form",
      "info": "Requires the Form Popup section to be on the template to work."
    },
    {
      "type": "checkbox",
      "id": "dont_show_slider_arrows",
      "label": "Don't show slider arrows",
      "info": "If each tab will only have one slide, check this box."
    }
  ],
  "blocks": [{"type": "@theme"}],
  "presets": [
    {
      "name": "t:settings_schema.sections.tabs_with_sliders.name"
    }
  ]
}
{% endschema %}
