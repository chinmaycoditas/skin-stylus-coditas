{%- assign s = section.settings -%}

<div 
  id="article-{{ s.id_number }}"
  class="lg:pt-[120px] pt-[100px]"
>
  <div class="lg:mx-9.5 mx-4.5 bg-white rounded-t-image lg:p-10 py-5 px-3">
    <div class="article-heading w-full pb-5 border-b border-b-grey-medium">
      <a href="{{ blog.url }}" class="underline text-blue-cta text-body tracking-[-0.032px] w-full lg:mb-5 mb-7.5 text-end block">{{ 'blog.articles.back_to_blog' | t }}</a>
      <span class="text-caption-small leading-4 tracking-[-0.2px]">{{ article.published_at | date: '%m . %d . %y' }}</span>
      <h3 class="lg:text-h2-mob text-h3-mob font-light lg:leading-12.5 leading-10 lg:tracking-[-0.09px] tracking-[-0.07px]{% unless settings.remove_capitalize %}capitalize{% endunless %}">{{ article.title }}</h3>
    </div>
    <div class="lg:py-[49px] py-10 lg:grid lg:grid-cols-6">
      <p class="text-section-1 font-light leading-8 tracking-[-0.056px] col-span-4{% unless settings.remove_capitalize %}capitalize{% endunless %} lg:pr-[50px] lg:border-r lg:border-r-grey-medium">{{ article.excerpt }}</p>
      <div class="col-span-2 lg:pl-[50px] lg:flex flex-col gap-6 hidden">
        <span class="lg:text-section-1 font-light lg:leading-8 lg:tracking-[-0.056]{% unless settings.remove_capitalize %}capitalize{% endunless %}">{{ 'blog.articles.categories' | t }}</span>
        <div class="flex flex-wrap gap-4">
          {% for tag in article.tags %}
            <span class="lg:px-4 lg:py-2 bg-soft-blue rounded-[126px] text-body-small text-blue-cta">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
    {% render 'responsive-image', image: article.image, class: 'w-full rounded-image', pb_hack: "58%" %}
    {% render 'scroll-to-top-button' %}
    <div class="lg:pt-[49px] pt-5 lg:pb-20 lg:grid lg:grid-cols-6">
      <div class="col-span-4 [&_*]:font-light lg:pr-[50px] border-b border-b-grey-medium lg:border-b-0 lg:border-r lg:border-r-grey-medium [&_p]:leading-[23px] [&_p]:tracking-[-0.032px] [&_p]:pb-6 [&_h4]:text-section-1 [&_h4]:leading-[32px] [&_h4]:tracking-[-0.056px] {% unless settings.remove_capitalize %}[&_h4]:capitalize{% endunless %} [&_h4]:pb-6 [&_h6]:text-section-1 [&_h6]:leading-[32px] [&_h6]:tracking-[-0.056px] [&_h6]:capitalize [&_h6]:pb-6 [&_ul]:list-disc [&_ul]:pl-12 [&_ol]:list-decimal [&_ol]:pl-12">
        {{ article.content }}
        <div class="w-full flex justify-center pb-5 pt-14.5 lg:hidden">
          {% render 'scroll-to-top-button' %}
        </div>
      </div>
      <div class="flex flex-col gap-6 py-10 lg:hidden">
        <span class="text-section-1 font-light leading-8 tracking-[-0.056]{% unless settings.remove_capitalize %}capitalize{% endunless %}">{{ 'blog.articles.categories' | t }}</span>
        <div class="flex flex-wrap gap-4">
          {% for tag in article.tags %}
            <span class="px-4 py-2 bg-soft-blue rounded-[126px] text-body-small text-blue-cta">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
      <div class="col-span-2 lg:pl-[50px] flex flex-col gap-10">
        <div class="w-full rounded-image px-7.5 pt-[30px] pb-[50px] flex flex-col gap-11 bg-soft-blue">
          <span class="text-section-3 leading-7 tracking-[-0.042px]">{{ s.connect_text }}</span>
          {% render 'social-icons', height: '30px', a_class: '[&_svg]:lg:!h-[30px] [&_svg]:!h-[23px] [&_svg]:!text-black' %}
        </div>
        <div class="w-full rounded-image p-[30px] flex flex-col gap-6 bg-soft-blue">
          <span class="text-section-3 leading-7 tracking-[-0.042px]">{{ s.locations_text }}</span>
          <a href="{{ s.cta_url }}" class="px-5 py-[15px] rounded-[70px] bg-blue-cta text-white text-body-small{% unless settings.remove_capitalize %}capitalize{% endunless %} w-fit">{{ s.cta_text }}</a>
        </div>
      </div>
    </div>
    <div>
      {% capture slider_options %}
        '
          {
            "perPage": 1,
            "pagination": false,
            "focus": "center",
            "arrows": false,
            "padding": {
              "left": "22px",
              "right": "40px"
            },
            "gap": "22px"
          }
        '
      {% endcapture %}
      {% if section.blocks.size > 0 %}
        <div class="lg:pt-12.5 pt-10 lg:pb-14.5 pb-7.5 lg:px-0 flex flex-col lg:gap-7.5 gap-4.5 x-border-t border-t-grey-medium">
          <span class="lg:text-section-1 text-section-3 lg:leading-8 leading-7 lg:tracking-[-0.056px] tracking-[-0.042px]{% unless settings.remove_capitalize %}capitalize{% endunless %}">{{ s.title }}</span>
          <div class="blogs-wrapper lg:grid grid-cols-3 gap-5.5">
            {% for block in section.blocks %}
              {% assign b = block.settings %}
              <div class="hidden lg:block">
                {% render 'article-card', article: b.article, image_class: 'lg:aspect-[103/70] aspect-[325/207] w-full rounded-image' %} 
              </div>
            {% endfor %}
            <div class="splide lg:hidden w-screen -translate-x-7.5" data-slider={{ slider_options }}>
              <div class="splide__track">
                <ul class="splide__list">
                  {% for block in section.blocks %}
                    {% assign b = block.settings %}
                    <li class="splide__slide">
                      {% render 'article-card', article: b.article, image_class: 'lg:aspect-[103/70] aspect-[325/207] rounded-image' %}
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </div> 
          </div>
        </div>  
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "t:settings_schema.sections.article.name",
    "class": "article no-max blog-article-gradient",
    "tag": "section",
    "settings": [
      {
      "type": "header",
      "content": "t:settings_schema.sections.article.featured_blogs_settings"
      },
      {
        "type": "text",
        "label": "t:settings_schema.general.title",
        "id": "title",
      },
      {
        "type": "header",
        "content": "t:settings_schema.sections.article.stay_up_to_date"
      },
      {
        "type": "text",
        "label": "t:settings_schema.sections.article.connect_text",
        "id": "connect_text",
        "default": "Connect to stay up to date with everything that’s happening at Hydrafacial"
      },
      {
        "type": "header",
        "content": "t:settings_schema.sections.article.find_near_you"
      },
      {
        "type": "text",
        "label": "t:settings_schema.sections.article.locations_text",
        "id": "locations_text",
        "default": "Want to see Hydrafacialists near you?"
      },
      {
        "type": "text",
        "label": "t:settings_schema.general.cta_text",
        "id": "cta_text",
        "default": "Find A Hydrafacialist"
      },
      {
        "type": "url",
        "label": "t:settings_schema.general.cta_url",
        "id": "cta_url",
      },
      {
        "type": "header",
        "content": "Unique Section ID"
      },
      {
        "type": "paragraph",
        "content": "The ID for this section will be 'article-#' based on the number chosen below. The default is 'article-1'"
      },
      {
        "type": "range",
        "id": "id_number",
        "label": "ID Number",
        "max": 5,
        "min": 1,
        "step": 1,
        "default": 1,
        "info": "If using this section multiple times on the same page, assign a different number to each one."
      }
    ],
    "blocks": [
      {
        "type": "article",
        "name": "t:settings_schema.sections.article.featured_stories",
        "settings": [
          {
            "type": "article",
            "label": "Article",
            "id": "article"
          }
        ],
        "limit": 3
      } 
    ],
    "presets": [
      {
        "name": "t:settings_schema.sections.article.name"
      }
    ]
  }
{% endschema %}
