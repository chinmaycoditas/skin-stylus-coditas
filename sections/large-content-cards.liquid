{%- assign s = section.settings -%}

{% capture slider_options %}
  '
    {
      "pagination": false,
      "start": 0,
      "snap": true,
      "gap": "22px",
      "arrows": false,
      "mediaQuery": "min",
      "padding": {"right": "54px", "left": "18px"},
      "breakpoints": {
        "1024": {
          "focus": 0,
          "pagination": false,
          "perPage": 3,
          "padding": {"right": "38px", "left": "38px"}
        }
      }
    }
  '
{% endcapture %}

<div 
  id="large-content-{{ s.id_number }}"
  class="flex flex-col gap-14.5 py-14.5">
  <div class="flex justify-center text-center w-full px-4.5 lg:px-0">
    <h2 class="lg:text-h2 text-h1-mob font-normal lg:leading-[70px] leading-[50px] lg:tracking-[-0.13px] tracking-[-0.09px] {% unless settings.remove_capitalize %}capitalize{% endunless %} max-w-[774px]">{% render 'blue', text: s.heading %}</h2>
  </div>
  <div class="splide max-w-screen" data-slider={{ slider_options }}>
    <div class="splide__track">
      <ul class="splide__list">
        {% for block in section.blocks %}
          {% assign b = block.settings %}

          <li class="splide__slide relative">
            {% if b.mobile_image != blank %}
              {%- render 'responsive-image', 
                image: b.mobile_image, 
                class: "lg:hidden rounded-image h-full w-full mobile__image", 
                cover: true 
              -%}
            {% endif %}
            {% if b.desktop_image != blank %}
              {%- render 'responsive-image',
                image: b.desktop_image, 
                class: "hidden lg:block rounded-image h-full",
                cover: true 
              -%}
            {% endif %}

            <div class="media__text-overlay flex flex-col absolute bottom-9 left-0 px-6.5">
              <div class="flex flex-col gap-1">
                <span class="text-section-1-mob font-medium leading-[25px] tracking-[-0.036px] text-white">{% render 'blue', text: b.title %}</span>
                <h4 class="text-h3-mob font-light leading-10 tracking-[-0.07px] mb-[30px] {% unless settings.remove_capitalize %}capitalize{% endunless %} text-white">{% render 'blue', text: b.caption %}</h4>
                {% if b.card_cta_text != blank %}
                  <a class="bg-white px-7.5 py-[15px] rounded-[70px] w-max" href="{{ b.card_cta_url }}" {% if b.card_cta_new_window %}target="_blank"{% endif %}>{{ b.card_cta_text }}</a>  
                {% endif %}
              </div>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>
<span class="mx-4.5 lg:mx-[38px] max-w-screen block">
  <span class="block w-full"></span>
</span>

{% schema %}
  {
    "name": "t:settings_schema.sections.large_content_cards.name",
    "tag": "section",
    "class": "section-large-content-cards",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "t:settings_schema.general.heading",
        "info": "t:settings_schema.general.blue_info"
      },
      {
        "type": "header",
        "content": "Unique Section ID"
      },
      {
        "type": "paragraph",
        "content": "The ID for this section will be 'large-content-#' based on the number chosen below. The default is 'large-content-1'"
      },
      {
        "type": "range",
        "id": "id_number",
        "label": "ID Number",
        "max": 5,
        "min": 1,
        "step": 1,
        "default": 1,
        "info": "If using this section multiple times on the same page, assign a different number to each one."
      }
    ],
    "blocks": [
      {
        "type": "media_slide",
        "name": "t:settings_schema.sections.large_content_cards.content_card",
        "settings": [
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "t:settings_schema.general.image_desktop"
          },
          {
            "type": "image_picker",
            "id": "mobile_image",
            "label": "t:settings_schema.general.image_mobile"
          },
          {
            "type": "text",
            "id": "title",
            "label": "t:settings_schema.general.eyebrow",
            "info": "t:settings_schema.general.blue_info"
          },
          {
            "type": "text",
            "id": "caption",
            "label": "t:settings_schema.general.caption",
            "info": "t:settings_schema.general.blue_info"
          },
          {
            "type": "text",
            "id": "card_cta_text",
            "label": "t:settings_schema.general.cta_button_text"
          },
          {
            "type": "url",
            "id": "card_cta_url",
            "label": "t:settings_schema.general.cta_button_url"
          },
          {
            "type": "checkbox",
            "id": "card_cta_new_window",
            "label": "Open CTA URL In a New Tab",
            "default": false
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "t:settings_schema.sections.large_content_cards.name"
      }
    ]
  }
{% endschema %}
