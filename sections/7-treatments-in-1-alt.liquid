{% assign s = section.settings %}
<div class="px-[18px] mt-[30px] lg:mt-10 pb-10 DEBUG">
  <div class="flex flex-col gap-[50px] lg:gap-[52px] pt-10 lg:pt-20 rounded-t-image seven-treatments-gradient">
    <div class="flex flex-col items-center gap-6 px-[18px] lg:max-w-[884px] mx-auto">
      <h2 class="text-center text-h1-mob/[50px] lg:text-h2/[70px] capitalize tracking-[-0.09px] lg:tracking-[-0.13px]">{% render 'blue', text: s.heading %}</h2>
      <p class="text-center text-body/[23px] font-light tracking-[-0.032px]">{% render 'blue', text: s.subheading %}</p>
    </div>

    <ul class="flex flex-col gap-10 w-full lg:flex-row lg:flex-wrap justify-center pb-10 lg:px-[100px]">
      {% for block in section.blocks %}
        {% assign b = block.settings %}
        <li class="w-full flex flex-col rounded-image lg:max-w-[20%]">
          {% render 'responsive-image', image: b.image, cover:true, pb_hack: "71.07%", class: "rounded-t-image" %}
          <div class="flex flex-col gap-2 h-full pt-[22px] px-5 pb-16 bg-toggle rounded-b-image">
            <h4 class="text-section-3/7 font-light tracking-[-0.042px]">{{ b.title }}</h4>
            <h5 class="text-body/[23px] font-light tracking-[-0.032px]">{{ b.body }}</h5>
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "t:settings_schema.sections.seven_treatments_in_1_alt.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings_schema.general.heading",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:settings_schema.general.subheading",
      "info": "t:settings_schema.general.blue_info"
    }
  ],
  "blocks": [
    {
      "type": "treatment",
      "name": "t:settings_schema.sections.seven_treatments_in_1_alt.treatment",
      "settings": [
        {
          "type": "text",
          "id": "pill",
          "label": "t:settings_schema.general.image_pill"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings_schema.general.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:settings_schema.general.title"
        },
        {
          "type": "text",
          "id": "body",
          "label": "t:settings_schema.general.body"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:settings_schema.sections.seven_treatments_in_1_alt.name"
    }
  ]
}
{% endschema %}
