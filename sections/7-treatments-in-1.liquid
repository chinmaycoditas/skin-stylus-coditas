{%- assign s = section.settings -%}

<div 
  id="7-treatments-{{ s.id_number }}"
  class="relative lg:mx-[38px] mx-4 mt-[30px] lg:mt-10 pb-10"
>
  <div class="flex flex-col gap-[50px] lg:gap-[52px] pt-10 lg:pt-20 rounded-t-image {% if s.use_gradient %}seven-treatments-gradient{% endif %}">
    <div class="flex flex-col items-center gap-6 px-[18px] lg:max-w-[884px] mx-auto">
      <h2 class="text-center text-h1-mob/[50px] lg:text-h2/[70px] {% unless settings.remove_capitalize %}capitalize{% endunless %} tracking-[-0.09px] lg:tracking-[-0.13px]">{% render 'blue', text: s.heading %}</h2>
      <h3 class="text-center text-body/[23px] font-light tracking-[-0.032px]">{% render 'blue', text: s.subheading %}</h3>
    </div>

    {%- if s.style == 'carousel' -%}
      {%- liquid
        assign carousel_ul = ' splide__list lg:w-full !justify-start lg:!justify-center lg:!flex lg:gap-10 lg:flex-row' 
        assign carousel_li = ' splide__slide'
      -%}

      {%- capture slider_options -%}
        '
          {
            "perPage": 1,
            "pagination": false,
            "focus": 0,
            "snap": true,
            "arrows": false,
            "gap": "22px",
            "fixedWidth": "71.95%",
            "padding": "18px",
            "mediaQuery": "min",
            "trimSpace": true,
            "breakpoints": {
              "1024": {
                "destroy": true,
                "padding": false
              }
            }
          }
        '
      {%- endcapture -%}

      <div class="splide" data-slider={{ slider_options }}>
        <div class="splide__track max-w-screen -mx-4 lg:mx-0">
    {%- endif -%}

    <ul class="{% unless s.style== 'carousel' %}flex flex-col gap-10 w-full {% endunless %}lg:flex-row lg:flex-wrap justify-center pb-10 lg:px-[100px]{{ carousel_ul }}">
      {% for block in section.blocks %}
        {% assign b = block.settings %}
        <li class="w-full flex flex-col rounded-image lg:max-w-[20%]{{ carousel_li }}">
          {% render 'responsive-image', image: b.image, cover:true, pb_hack: "71.07%", class: "rounded-t-image" %}
          <div class="flex flex-col gap-2 h-full pt-[22px] px-5 pb-16 bg-toggle rounded-b-image">
            <h4 class="text-section-3/7 font-light tracking-[-0.042px]">{{ b.title }}</h4>
            <h5 class="text-body/[23px] font-light tracking-[-0.032px]">{{ b.body }}</h5>
          </div>
        </li>
      {% endfor %}
    </ul>

    {%- if s.style == 'carousel' -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:settings_schema.sections.seven_treatments_in_1.name",
  "tag": "section",
  "class": "no-max",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "t:settings_schema.general.display.use_gradient"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings_schema.general.heading",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:settings_schema.general.subheading",
      "info": "t:settings_schema.general.blue_info"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:settings_schema.general.style.label",
      "options": [
        {
          "label": "t:settings_schema.general.style.options.carousel",
          "value": "carousel"
        },
        {
          "label": "t:settings_schema.general.style.options.stacked",
          "value": "stacked"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "header",
      "content": "Unique Section ID"
    },
    {
      "type": "paragraph",
      "content": "The ID for this section will be '7-treatments-#' based on the number chosen below. The default is '7-treatments-1'"
    },
    {
      "type": "range",
      "id": "id_number",
      "label": "ID Number",
      "max": 5,
      "min": 1,
      "step": 1,
      "default": 1,
      "info": "If using this section multiple times on the same page, assign a different number to each one."
    }
  ],
  "max_blocks": 7,
  "blocks": [
    {
      "type": "treatment",
      "name": "t:settings_schema.sections.seven_treatments_in_1.treatment",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:settings_schema.general.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:settings_schema.general.title"
        },
        {
          "type": "text",
          "id": "body",
          "label": "t:settings_schema.general.body"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:settings_schema.sections.seven_treatments_in_1.name"
    }
  ]
}
{% endschema %}
