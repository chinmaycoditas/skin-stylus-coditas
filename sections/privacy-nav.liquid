{%- assign s = section.settings -%}

<div 
  id="privacy-nav-{{ s.id_number }}"
  class="w-screen max-w-maxscreen mx-auto mt-[80px] lg:mt-[100px] py-4 mb-4 lg:mb-0 px-6 flex flex-col lg:flex-row justify-center lg:justify-between items-center gap-4 overflow-visible">
  <a class="text-blue-cta hover:underline" href="{{ page.metafields.custom.privacy_connected_url }}">
    {{ page.metafields.custom.privacy_connected_label }}
  </a>
  
  {% unless request.path contains 'request-form' or request.host != 'www.hydrafacial.com' %}
    <div class="flex items-center gap-4">
      <span>{{ 'general.language' | t }} :</span>
      <div class="relative">
        <label class="flex items-center cursor-pointer">
          <input id="language-dropdown" type="checkbox" class="peer hidden" data-close-on-scroll />
          
          <label for="language-dropdown" class="
            flex items-center justify-between gap-2 
            px-4 py-2 
            border border-gray-300 rounded 
            bg-white hover:bg-gray-50 
            min-w-[120px]
            peer-checked:bg-gray-50
            peer-checked:border-blue-500
          ">
            {% for block in section.blocks %}
              {%- liquid
                assign b = block.settings 

                assign handle = b.url | split: ".com/pages/" | last | split: '?' | first | split: '/' | first
                assign page_object = pages[handle]

                if page_object.url == page.url
                  assign page_match_found = true
                endif
              -%}

              {% if page_match_found %}
                <span>{{ b.language_name }}</span>
                <svg class="w-4 h-4 transition-transform peer-checked:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>

                {%- break -%}
              {% endif %}
            {% endfor %}
          </label>
          
          <!-- Dropdown Menu -->
          <div class="
            absolute top-full right-0 mt-1 
            w-48 max-h-64 overflow-y-auto
            bg-white border border-gray-300 rounded shadow-lg
            opacity-0 invisible peer-checked:opacity-100 peer-checked:visible
            transition-all duration-200 ease-in-out
            z-50
          ">
            {% for block in section.blocks %}
              {% assign b = block.settings %}
              {% if b.language_code and b.language_name %}
                <a 
                  href="{{ b.url | default: '#' }}" 
                  class="
                    block px-4 py-2 text-gray-700 hover:bg-gray-100 hover:text-gray-900
                    transition-colors duration-150
                    {% if b.language_code == s.current_language_code %}bg-blue-50 text-blue-700{% endif %}
                  "
                  role="button"
                  tabindex="0"
                  data-language="{{ b.language_code }}"
                  {% if b.language_code == s.current_language_code %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
                >
                  {{ b.language_name }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </label>
      </div>
    </div>
  {% endunless %}
</div>

{% schema %}
{
