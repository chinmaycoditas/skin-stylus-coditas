<div class="password-section">
  <div class="password-container">
    <div class="password-header">
      <h1>{{ shop.name }}</h1>
    </div>

    <div class="password-form-container">
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <input type="password" name="password" id="password" placeholder="Enter password">
        <button type="submit" name="commit">
          Enter
        </button>
      {% endform %}
    </div>
  </div>
</div>

<style>
  .password-section {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
  }

  .password-container {
    max-width: 400px;
    width: 100%;
    text-align: center;
  }

  .password-header h1 {
    margin-bottom: 20px;
    font-size: 2.5rem;
  }

  .password-message {
    margin-bottom: 30px;
    font-size: 1.1rem;
    color: #666;
  }

  .password-form-container,
  .email-signup-container {
    margin-bottom: 30px;
  }

  .password-form-container label,
  .email-signup-container label {
    display: block;
    margin-bottom: 10px;
    font-weight: bold;
  }

  .password-form-container input,
  .email-signup-container input {
    width: 100%;
    padding: 12px;
    margin-bottom: 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
  }

  .password-form-container button,
  .email-signup-container button {
    width: 100%;
    padding: 12px;
    background-color: #007cba;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .password-form-container button:hover,
  .email-signup-container button:hover {
    background-color: #005a87;
  }

  .email-signup-container h3 {
    margin-bottom: 15px;
    color: #333;
  }

  .errors {
    color: #d32f2f;
    margin-bottom: 15px;
  }

  .errors li {
    list-style: none;
    margin-bottom: 5px;
  }
</style>

{% schema %}
{
  "name": "t:settings_schema.sections.storefront_password.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_email_signup",
      "label": "t:settings_schema.sections.storefront_password.show_email_signup",
      "default": true
    },
    {
      "type": "text",
      "id": "email_signup_title",
      "label": "t:settings_schema.sections.storefront_password.email_signup_title",
      "default": "Stay Updated"
    }
  ],
  "presets": [
    {
      "name": "t:settings_schema.sections.storefront_password.name"
    }
  ]
}
{% endschema %}
