{%- assign s = section.settings -%}

<div 
  id="image-with-text-{{ s.id_number }}"
  class="py-4 mx-4 lg:py-[60px] py-10 lg:mx-auto">
  <ul class="flex flex-col">
  {% for block in section.blocks %}
    {%- liquid
      assign b = block.settings
      assign reverse = false
      assign modulo = forloop.index | modulo: 2

      if s.first_image_position == 'left'
        if modulo == 0
          assign reverse = true
        endif
      else 
        if modulo != 0
          assign reverse = true
        endif
      endif
    -%}
    
    <li class="flex flex-col-reverse {% if reverse %}lg:flex-row-reverse{% else %}lg:flex-row{% endif %} gap-[30px] lg:gap-[50px] lg:py-0">
      {% render 'responsive-image', image: b.mobile_image, class: "lg:hidden aspect-[1.4] rounded-image", cover: true  %}
      {% render 'responsive-image', image: b.desktop_image, class: "hidden lg:block w-[55%] aspect-[1.4] rounded-image", cover: true %}

      <div class="flex flex-col gap-[22px] lg:w-[45%]">
        <h2 class="text-h3-mob/10 lg:text-h3/[60px] font-light {% unless settings.remove_capitalize %}capitalize{% endunless %} tracking-[-0.07px] lg:tracking-[-0.11px]">
          {% render 'blue', text: b.heading %}
        </h2>
        <p class="text-body/[23px] font-light tracking-[-0.032px]">
          {% render 'blue', text: b.subheading %}
        </p>
        {%- if b.button_url -%}
          <a class="button-primary-black {% if settings.remove_capitalize %}!normal-case{% endif %} mt-2 lg:mt-3 w-fit" href="{{ b.button_url }}">
            <span>{{ b.button_text }}</span>
          </a>
        {%- endif -%}
      </div>
    </li>
  {% endfor %}
  </ul>
</div>

{% schema %}
{
  "name": "t:settings_schema.sections.image_with_text.name",
  "tag": "section",
  "settings": [
    {
      "type": "radio",
      "id": "first_image_position",
      "label": "t:settings_schema.sections.image_with_text.first_image_position",
      "info": "t:settings_schema.sections.image_with_text.first_image_info",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:settings_schema.general.locations.left"
        },
        {
          "value": "right",
          "label": "t:settings_schema.general.locations.right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Unique Section ID"
    },
    {
      "type": "paragraph",
      "content": "The ID for this section will be 'image-with-text-#' based on the number chosen below. The default is 'image-with-text-1'"
    },
    {
      "type": "range",
      "id": "id_number",
      "label": "ID Number",
      "max": 5,
      "min": 1,
      "step": 1,
      "default": 1,
      "info": "If using this section multiple times on the same page, assign a different number to each one."
    }
  ],
  "blocks": [
    {
      "type": "image_and_text",
      "name": "t:settings_schema.sections.image_with_text.image_and_text",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "t:settings_schema.general.image_desktop"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "t:settings_schema.general.image_mobile"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:settings_schema.general.heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:settings_schema.general.subheading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:settings_schema.general.cta_button_text"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:settings_schema.general.cta_button_url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:settings_schema.sections.image_with_text.name"
    }
  ]
}
{% endschema %}
