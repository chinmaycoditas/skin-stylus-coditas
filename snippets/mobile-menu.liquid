{% assign s = section.settings %}
{% comment %} has-[[data-scroll-lock]:checked]:!overflow-hidden {% endcomment %}
<input id="mobile-menu-toggle" type="checkbox" class="peer/mobile-menu-toggle hidden" data-scroll-lock/>
<aside class="fixed top-0 bg-grey w-full h-full -right-full peer-checked/mobile-menu-toggle:right-0 transition-all pointer-events-auto">
  <div class="grid grid-rows-[auto_auto_1fr_auto] h-full w-full">
      <div class="blur-target flex justify-between items-center px-[18px] pt-4 pb-2.5 bg-white">
        <a href="{{ routes.root_url }}">
          {% render 'logo-svg' class: "translate-y-[3px] text-black w-[195px] h-10" %}
        </a>
        <label for="mobile-menu-toggle">
          {% render 'icons', icon: 'x', class: '[&_svg]:text-black [&_svg]:w-full' %}
        </label>
      </div>
    <div class="blur-target px-4 {% if s.show_search_bar %}mt-8 mb-14{% else %}mt-[22px]{% endif %}">
      <form class="flex items-center gap-4 bg-white p-[15px] rounded-sm shadow-custom-small {% unless s.show_search_bar %}!hidden{% endunless %}">
        {% render 'icons', icon: 'search' %}
        <input
          type="text" 
          name="search" 
          id="search" 
          placeholder="{{ 'general.search' | t }}" 
          class="placeholder:text-dark-grey placeholder:text-body-mob/[23px] placeholder:font-light placeholder:tracking-[-0.032px] placeholder:align-middle"
        />
      </form>
    </div>
    <ul class="blur-target flex flex-col gap-[22px] overflow-scroll no-scrollbar px-4 pb-[72px]" data-hc-body-click-toggle="mob-menu-accordion">
      {% assign link_class = "font-primary text-section-2/8 font-light tracking-[-0.056px]" %}

      {% for link in s.main_menu.links %}
        <li class="{% unless forloop.last %}border-b-grey-medium border-b pb-[22px]{% endunless %}">
          {% if link.links == blank %}
            <a href="{{ link.url }}" class="{{ link_class }}{% unless settings.remove_capitalize %}capitalize{% endunless %}">{{ link.title }}</a>
          {% else %}
            <div
              data-hc-control="{{ link.title }}"
              class="group flex justify-between items-center relative {{ link_class }}{% unless settings.remove_capitalize %}capitalize{% endunless %}"
            >
              <span>{{ link.title }}</span>
              {% render 'icons', icon: 'chevron-down' class: "flex items-center text-black [&_svg]:w-5 group-[&.is-active]:rotate-180 transition-all" %}
            </div>
          
            <div data-hc-content="{{ link.title }}" class="flex flex-col gap-9">
              <ul class="flex flex-col gap-8">
                {% for child_link in link.links %}
                  <li class="{% if forloop.first %}pt-9{% endif %}">
                    <a 
                      href="{{ child_link.url }}" 
                      class="text-section-3/7 font-light tracking-[-0.042px]"
                    >
                      {{ child_link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
              <a href="{{ link.url }}" class="button-primary-black {% if settings.remove_capitalize %}!normal-case{% endif %} mt-9 max-w-[174px]">See All</a>
            </div>
          {% endif %}
        </li>
      {% endfor %}
    </ul>

    <div data-blur class="blur-target bg-blurer bg-white px-[18px] py-[18px] flex flex-col gap-10 relative">
      <ul class="bg-blurer flex flex-col gap-4">
        {% for block in section.blocks %}
          {% if block.type == 'header_cta' %}
            <li class="w-full">
              <a href="{{ block.settings.link }}" class="block w-full text-center py-3 {{ block.settings.button_type_mobile }}">
                <span class="leading-square">{{ block.settings.label }}</span>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
      <label class="group">
        <input data-dropdown-input id="regions-menu-toggle" type="checkbox" class="hidden peer" />

        <div 
          data-scroll-container
          class="bg-blurer absolute bottom-[37%] max-h-0 peer-checked:max-h-full overflow-scroll left-0 w-full transition-all"
        >
          <ul class="relative flex flex-col gap-2 py-4 bg-grey border-b-[0.5px] border-b-grey-medium">
            {% for region in s.region_menu.links %}
              {% render 'region', context: 'mobile-menu', region: region %}
            {% endfor %}
          </ul>
        </div>

        <div class="bg-blurer group flex items-center justify-between border-t-[0.5px] border-t-grey-medium py-6">
          <div class="flex gap-2">
            {% render 'icons', icon: 'globe', class: "[&_svg]:text-black" %}
            {%- if request.host == 'www.hydrafacial.com' -%}
              <span class="font-light">US & Canada</span>
            {%- endif -%}
          </div>
          {% render 'icons', icon: "chevron-down" class: "text-black w-3 h-3 pt-[3px] group-has-[input:checked]:rotate-180 transition-all" %}
        </div>
      </label>
    </div>
  </div>
</aside>
