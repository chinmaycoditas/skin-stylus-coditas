<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <!-- Start of Shoplift scripts -->
    {% render 'shoplift' %}
    <!-- End of Shoplift scripts -->

    <!-- OneTrust + Shopify Privacy Integration -->
    {% render 'customer-privacy' %}
    <!-- End Privacy Integration -->

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% render 'meta-tags' %}

    {{ content_for_header }}

    {% render 'css-variables' %}

    <link rel="preload" as="stylesheet" href="{{ 'global.vbt.css' | asset_url }}">
    {{ 'global.vbt.css' | asset_url | stylesheet_tag }}

    <link rel="preload" as="script" href="{{ 'global.vbt.js' | asset_url }}">
    <script type="module" src="{{ 'global.vbt.js' | asset_url }}"></script>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) { document.documentElement.classList.add('shopify-design-mode'); }
    </script>
    <script type="text/javascript"> (function(c,l,a,r,i,t,y){ c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)}; t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i; y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y); })(window, document, "clarity", "script", "so5d4uh8k2"); </script>

  </head>

  <body class="font-primary group/body [&:has([data-scroll-lock]:checked)]:overflow-hidden" style="min-height: 100vh;">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5XK4HZDK"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    {% render 'gradients' %}

    <a class="skip-to-content-link button hidden" href="#MainContent">
      {{ "accessibility.skip_to_text" | t }}
    </a>
    
    {% if template == 'password' %}
      <div style="padding:20px">
        {% form 'storefront_password' %}
          {{ form.errors | default_errors }}
        
          <div class="password">
            <label for="password">Password</label>
            <input type="password" name="password">
          </div>
        
          <div class="submit">
            <input type="submit" value="Sign in">
          </div>
        {% endform %}
      </div>
    {% else %}  
      {% render 'eyebrow-navigation' %}

      {% if page.metafields.custom.use_alt_header or collection.metafields.custom.use_alt_header or product.metafields.custom.use_alt_header %}
        {% section 'header-alt' %}
      {% else %}
        {% section 'header' %}
      {% endif %}

      <main id="MainContent" role="main" tabindex="-1">
        {% if template contains 'page' and page.handle contains 'privacy' %}
          {% section 'privacy-nav' %}
        {% endif %}

        {{ content_for_layout }}
      </main>
      {% section 'footer' %}
    {% endif %}
  </body>

  {% section 'app-optimization' %}
</html>
